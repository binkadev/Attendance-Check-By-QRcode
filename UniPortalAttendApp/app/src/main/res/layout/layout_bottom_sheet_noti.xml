<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#D1D5DB"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/bsIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_announcement"
            app:tint="#3B82F6"
            android:background="@drawable/bg_icon_circle_blue"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/bsTitle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Tiêu đề thông báo"
            android:textColor="#0A2540"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/bsMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nội dung chi tiết của thông báo..."
        android:textColor="#4B5563"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.2"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bsDetailsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E5E7EB"
        app:cardBackgroundColor="#F9FAFB">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/bsDetailsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chi tiết thông số..."
                android:textColor="#374151"
                android:textSize="14sp"
                android:lineSpacingExtra="6dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/bsBtnClose"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Đã hiểu"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:backgroundTint="#A6192E" />

</LinearLayout>