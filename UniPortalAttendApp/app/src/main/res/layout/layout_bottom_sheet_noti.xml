<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet"> <View
    android:layout_width="40dp"
    android:layout_height="4dp"
    android:background="#D1D5DB"
    android:layout_gravity="center_horizontal"
    android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/bsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tiêu đề thông báo"
        android:textColor="#0A2540"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/bsMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nội dung chi tiết của thông báo..."
        android:textColor="#4B5563"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/bsBtnClose"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Đã hiểu"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:backgroundTint="#A6192E" />

</LinearLayout>