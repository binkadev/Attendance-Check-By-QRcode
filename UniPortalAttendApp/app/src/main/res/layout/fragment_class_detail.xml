<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:paddingBottom="90dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_circle_gray"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="#0A2540"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chi tiết Lớp học"
                android:textColor="#0A2540"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:background="#A6192E"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvCourseClassCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MAT101 • Nhóm 01"
                        android:textColor="#A6192E"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvClassName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toán Cao Cấp"
                        android:textColor="#0A2540"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvSemesterYear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Học kỳ 1 - Năm học 2023-2024"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_pill_gray"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_time"
                            app:tint="#9CA3AF"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thời gian"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tvTimeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thứ 2, 08:00 - 09:30"
                                android:textColor="#0A2540"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_pill_gray"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_location"
                            app:tint="#9CA3AF"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phòng học"
                                android:textColor="#9CA3AF"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tvRoomValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phòng 302-A"
                                android:textColor="#0A2540"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bản đồ"
                            android:textColor="#A6192E"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAttendQR"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="Điểm danh bằng QR"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        app:icon="@drawable/ic_qr_code"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#A6192E"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F9FAFB">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sample_avatar"
                    app:shapeAppearanceOverlay="@style/CircleImageView"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giảng viên phụ trách"
                        android:textColor="#6B7280"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvLecturerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PGS.TS Trần Văn B"
                        android:textColor="#0A2540"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_email"
                            app:tint="#A6192E"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Liên hệ"
                            android:textColor="#A6192E"
                            android:textSize="12sp"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAttendanceStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thống kê chuyên cần"
                    android:textColor="#0A2540"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Số buổi vắng:"
                        android:textColor="#6B7280"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvAbsentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2/3 buổi"
                        android:textColor="#EF4444"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbAbsenceWarning"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="3"
                    android:progress="2"
                    android:progressTint="#F59E0B"
                    android:progressBackgroundTint="#E5E7EB"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Tình trạng thi:"
                        android:textColor="#6B7280"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvExamStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nguy cơ cấm thi"
                        android:textColor="#F59E0B"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_pill_gray"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="* Lưu ý: Sinh viên vắng quá 3 buổi sẽ bị cấm thi."
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:textStyle="italic"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lịch sử điểm danh"
                android:textColor="#0A2540"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>
            <TextView
                android:id="@+id/tvAttendanceSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang tải..."
                android:textColor="#4B5563"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_pill_gray"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- RECYCLERVIEW cho ds ls diem danh -->
        <androidx.recyclerview.widget.RecyclerView
