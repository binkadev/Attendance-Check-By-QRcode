<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:paddingBottom="90dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_circle_gray"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="#0A2540"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kết quả điểm danh"
                android:textColor="#0A2540"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="1dp"
            app:strokeColor="#F3F4F6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="24dp">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_check_green"
                    android:background="@drawable/bg_circle_green_light"
                    android:padding="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Điểm danh thành công!"
                    android:textColor="#0A2540"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_marginTop="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bạn đã được ghi nhận có mặt tại lớp."
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginVertical="24dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_book"
                        android:background="@drawable/bg_circle_gray_light"
                        android:padding="10dp"
                        app:tint="#6B7280"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MÔN HỌC"
                            android:textColor="#9CA3AF"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvClassName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kỹ thuật phần mềm"
                            android:textColor="#0A2540"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"/>
                        <TextView
                            android:id="@+id/tvClassId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mã lớp: SE102.N11"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_time"
                        android:background="@drawable/bg_circle_gray_light"
                        android:padding="10dp"
                        app:tint="#6B7280"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="THỜI GIAN GHI NHẬN"
                            android:textColor="#9CA3AF"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView android:id="@+id/tvTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="09:15 AM - 25/04/2026"
                            android:textColor="#0A2540"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvStatusLabel"
                            android:text="Đúng giờ"
                            android:textColor="#10B981"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_location"
                        android:background="@drawable/bg_circle_gray_light"
                        android:padding="10dp"
                        app:tint="#6B7280"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ĐỊA ĐIỂM"
                            android:textColor="#9CA3AF"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phòng A1.102"
                            android:textColor="#0A2540"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/tvLocationSubtitle"
                            android:text="Tòa nhà A1"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="Xong"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="#A6192E"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanAgain"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Quét lại"
            android:textColor="#0A2540"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB"
            app:backgroundTint="#FFFFFF"
            app:elevation="0dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>