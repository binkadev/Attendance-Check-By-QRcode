<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#F9FAFB">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_toStartOf="@+id/btnArrow">

            <TextView android:id="@+id/tvGroupName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên môn học" android:textColor="#0A2540" android:textStyle="bold" android:textSize="14sp"/>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp" android:gravity="center_vertical">
                <ImageView android:layout_width="12dp" android:layout_height="12dp" android:src="@drawable/ic_time" app:tint="#6B7280"/>
                <TextView android:id="@+id/tvTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="08:00 - 09:30" android:textColor="#6B7280" android:textSize="12sp" android:layout_marginStart="4dp"/>
                <ImageView android:layout_width="12dp" android:layout_height="12dp" android:src="@drawable/ic_location" app:tint="#6B7280" android:layout_marginStart="16dp"/>
                <TextView android:id="@+id/tvRoom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phòng" android:textColor="#6B7280" android:textSize="12sp" android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- KHỐI AVATAR (MỚI THÊM) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <!-- Bạn có thể set cứng 3 ảnh icon person nhỏ ở đây, vì việc tải ảnh thật dạng chồng chéo (overlapping) trên Android cần custom View khá phức tạp, ta dùng ảnh giả lập trước -->
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_person" android:background="@drawable/bg_icon_circle_gray" android:padding="4dp"/>
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_person" android:background="@drawable/bg_icon_circle_gray" android:padding="4dp" android:layout_marginStart="-6dp"/>
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_person" android:background="@drawable/bg_icon_circle_gray" android:padding="4dp" android:layout_marginStart="-6dp"/>

                <TextView
                    android:id="@+id/tvStudentCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+24"
                    android:textSize="10sp"
                    android:textColor="#6B7280"
                    android:background="@drawable/bg_pill_gray"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <ImageView android:id="@+id/btnArrow" android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_arrow_right" android:background="@drawable/bg_icon_circle" android:padding="6dp" app:tint="#9CA3AF" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>