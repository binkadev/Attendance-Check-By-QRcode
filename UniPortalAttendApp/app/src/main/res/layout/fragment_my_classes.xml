<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="90dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lớp học của tôi"
                android:textColor="#0A2540"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>
            <ImageView
                android:id="@+id/imgAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_icon_circle_gray"
                android:padding="8dp"
                android:src="@drawable/ic_person"
                app:tint="#6B7280" />
        </RelativeLayout>

        <!-- THANH TÌM KIẾM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_pill_gray"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="#6B7280"/>
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Tìm kiếm lớp học, mã môn..."
                android:textSize="14sp"
                android:textColor="#0A2540"
                android:textColorHint="#9CA3AF"
                android:layout_marginStart="8dp"
                android:inputType="text"/>
        </LinearLayout>

        <!-- FILTER TABS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnFilterSemester"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Học kỳ 1 - 2023  ▼"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:background="@drawable/bg_chip_active"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btnTabJoined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã tham gia"
                    android:textColor="#0A2540"
                    android:textSize="12sp"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btnTabUnattended"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa điểm danh"
                    android:textColor="#0A2540"
                    android:textSize="12sp"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginTop="20dp"/>

        <!-- DASHBOARD (MẶC ĐỊNH HIỂN THỊ) -->
        <LinearLayout
            android:id="@+id/layoutDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- THẺ HỌC KỲ HIỆN TẠI -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FEF2F2"
                app:strokeWidth="1dp"
                app:strokeColor="#FECDD3">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HỌC KỲ HIỆN TẠI"
                            android:textColor="#A6192E"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Học kỳ 1 - Năm học 2023-2024"
                            android:textColor="#0A2540"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_calendar_red"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="6dp"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TIÊU ĐỀ: HÔM NAY -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HÔM NAY"
                    android:textColor="#0A2540"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvTodayCount"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_badge_circle_red"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- DANH SÁCH LỚP HÔM NAY TỪ API -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTodayClasses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp"/>

            <!-- THÔNG BÁO NẾU HÔM NAY KHÔNG CÓ LỊCH -->
            <TextView
                android:id="@+id/tvEmptyToday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tuyệt vời! Bạn không có môn học nào hôm nay."
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

            <!-- TIÊU ĐỀ: NGÀY MAI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LỊCH HỌC SẮP TỚI (NGÀY MAI)"
                android:textColor="#0A2540"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- DANH SÁCH LỚP NGÀY MAI TỪ API -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTomorrowClasses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp"/>

            <!-- THÔNG BÁO NẾU NGÀY MAI KHÔNG CÓ LỊCH -->
            <TextView
                android:id="@+id/tvEmptyTomorrow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chưa có lịch học cho ngày mai."
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>

        <!-- DANH SÁCH TẤT CẢ LỚP (HIỆN KHI BẤM TAB KHÁC) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClasses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false"
            android:paddingBottom="20dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>


