<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/white">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mời sinh viên tham gia"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quét mã QR dưới đây để vào lớp"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"/>

        <ImageView
            android:id="@+id/ivDialogQrCode"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_marginTop="24dp"
            android:background="#FAFAFA"
            android:padding="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_badge_gray"
            android:backgroundTint="#F0F0F0"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã lớp: "
                android:textSize="16sp"
                android:textColor="#757575"/>

            <TextView
                android:id="@+id/tvDialogJoinCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABCXYZ"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:textIsSelectable="true"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseDialog"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="24dp"
            android:text="Đóng"
            android:textColor="#757575"
            app:backgroundTint="#EEEEEE"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>